# ============================================================
# PulseTrace — Environment Variables (Production)
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ============================================================

# ---- ShaktiDB (PostgreSQL 17 fork by IIT Madras) ----
# ShaktiDB uses the default 'postgres' user without a password
POSTGRES_USER=postgres
POSTGRES_DB=shakthidb
POSTGRES_HOST=shakthidb
POSTGRES_PORT=5432

# Async connection string for SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres@shakthidb:5432/shakthidb

# ---- Backend (FastAPI) ----
API_KEY=changeme_generate_a_secure_uuid
GROQ_API_KEY=
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Enforce WARNING level in production to prevent log flooding
LOG_LEVEL=WARNING
CORS_ORIGINS=["https://dashboard.yourdomain.com"]

# ---- Agent (Run on Target Machines) ----
AGENT_BACKEND_URL=https://api.yourdomain.com
AGENT_API_KEY=changeme_generate_a_secure_uuid
COLLECTION_INTERVAL=5
TOP_PROCESSES=10
AGENT_HOSTNAME=
