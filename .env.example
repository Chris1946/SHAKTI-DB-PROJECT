# ============================================================
# PulseTrace — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ============================================================

# ---- PostgreSQL (ShakthiDB) ----
POSTGRES_USER=pulsetrace
POSTGRES_PASSWORD=changeme_use_strong_password
POSTGRES_DB=shakthidb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Async connection string for SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://pulsetrace:changeme_use_strong_password@localhost:5432/shakthidb

# ---- Backend (FastAPI) ----
API_KEY=changeme_generate_a_uuid
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- Agent ----
AGENT_BACKEND_URL=http://localhost:8000
AGENT_API_KEY=changeme_generate_a_uuid
COLLECTION_INTERVAL=5
TOP_PROCESSES=10
AGENT_HOSTNAME=
